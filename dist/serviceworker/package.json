{
  "name": "icinga-notifications-worker",
  "version": "0.0.1",
  "description": "semi-persistent ServiceWorker which acts as a \"Server Sent Events\"-Receiver and triggers notifications (cross-browser support)",
  "main": "source/icinga-notifications-worker.ts",
  "scripts": {
    "test:chrome": "npx playwright test --headed --browser=chromium",
    "test:firefox": "npx playwright test --headed --browser=firefox",
    "test:safari": "npx playwright test --headed --browser=webkit",
    "test:all": "npx playwright test --headed --browser=all",
    "build": "node ./esbuild.js",
    "build-prod": "node ./esbuild-prod.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Icinga/icinga-notifications-web.git"
  },
  "keywords": [
    "sse",
    "server",
    "sent",
    "events",
    "service",
    "worker",
    "notifications"
  ],
  "author": "Noé Costa",
  "license": "GPL-2.0",
  "bugs": {
    "url": "https://github.com/Icinga/icinga-notifications-web/issues"
  },
  "homepage": "https://github.com/Icinga/icinga-notifications-web#readme",
  "dependencies": {
    "esbuild": "^0.19.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "http-server": "^14.1.1"
  },
  "type": "module"
}
